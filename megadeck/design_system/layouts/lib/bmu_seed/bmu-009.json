      "width_in": 11.13,
      "height_in": 0.45,
      "text": "Most engineer-founded startups fail not on tech, but on these",
      "font_size_pt": 16.0,
      "font_bold": false,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "94A3B8",
