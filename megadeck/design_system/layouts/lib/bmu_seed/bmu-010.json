      "width_in": 10.83,
      "height_in": 0.7575,
      "text": "Spending on ads before you understand the customer.  Burning cash without learning is the worst kind of burn.",
      "font_size_pt": 21.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
