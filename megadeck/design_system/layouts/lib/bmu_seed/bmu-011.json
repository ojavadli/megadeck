      "top_in": 3.05,
      "width_in": 10.83,
      "height_in": 0.7575,
      "text": "Sign a vesting schedule from day one.  Four years with a one-year cliff is the standard. Protects you both.",
      "font_size_pt": 21.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
