      "left_in": 1.4,
      "top_in": 5.045,
      "width_in": 10.83,
      "height_in": 0.7575,
      "text": "Talk every week about the relationship, not just the work.  Small frictions compound. Surface them while they are small.",
      "font_size_pt": 21.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
