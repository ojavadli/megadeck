      "left_in": 1.4,
      "top_in": 4.047498906386702,
      "width_in": 10.83,
      "height_in": 0.7575,
      "text": "Define equity, decision rights, and exit clauses BEFORE building.  Hard conversations are easier when nothing is at stake.",
      "font_size_pt": 21.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "090B11",
