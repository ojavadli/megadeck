    {
      "role": "body",
      "left_in": 1.4,
      "top_in": 3.05,
      "width_in": 10.83,
      "height_in": 0.65,
      "text": "Pick one customer.  Not 'small businesses' \u2014 one specific persona, by name, with one specific job to be done.",
      "font_size_pt": 19.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "090B11",
      "fill": null,
      "alignment": "left",
      "z": 4
    },
    {
      "role": "body",
      "left_in": 1.4,
      "top_in": 3.88,
      "width_in": 10.83,
      "height_in": 0.65,
      "text": "Pick a beachhead market.  A small market you can dominate fully before expanding. Like Facebook starting only at Harvard.",
      "font_size_pt": 19.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "090B11",
      "fill": null,
      "alignment": "left",
      "z": 6
    },
    {
      "role": "body",
      "left_in": 1.4,
      "top_in": 4.71,
      "width_in": 10.83,
      "height_in": 0.65,
      "text": "Map their full life day.  Understand the customer's day before, during, and after using your product.",
      "font_size_pt": 19.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "090B11",
      "fill": null,
      "alignment": "left",
      "z": 8
    },
    {
      "role": "body",
      "left_in": 1.4,
      "top_in": 5.54,
      "width_in": 10.83,
      "height_in": 0.65,
      "text": "Quantify the value.  Show the customer in dollars or hours how much they save. Vague benefits do not sell.",
      "font_size_pt": 19.0,
      "font_bold": true,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": "090B11",
      "fill": null,
      "alignment": "left",
      "z": 10
    },
    {
      "role": "body",
