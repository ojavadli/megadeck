      "width_in": 10.985507436570428,
      "height_in": 1.0770833333333334,
      "text": "As a result GEPA outperforms GRPO by +10% using 35\u00d7 fewer rollouts, MIPROv2 by +14%  because reflection extracts more signal from each rollout.",
      "font_size_pt": null,
      "font_bold": false,
      "font_italic": false,
      "font_name": "SF Pro Display",
      "color": null,
      "fill": null,
